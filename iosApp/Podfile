platform :ios, '16.0'
use_frameworks! :linkage => :static

target 'iosApp' do
  # The KMP cocoapods plugin generates 'app.podspec' (named after the Gradle module).
  # It provides the MediLert.framework and all Firebase pod dependencies.
  pod 'app', :path => '../app'
  pod 'FirebaseCore'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Disable user script sandboxing for all pod targets so that
      # [CP] Copy XCFrameworks phases can write to the build directory.
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

      # abseil uses #include "absl/..." internally; add the abseil root to
      # HEADER_SEARCH_PATHS so the compiler can resolve them.
      config.build_settings['HEADER_SEARCH_PATHS'] ||= '$(inherited)'
      paths = config.build_settings['HEADER_SEARCH_PATHS']
      absl_path = '"${PODS_ROOT}/abseil"'
      if paths.is_a?(Array)
        config.build_settings['HEADER_SEARCH_PATHS'] << absl_path unless paths.include?(absl_path)
      else
        config.build_settings['HEADER_SEARCH_PATHS'] = "#{paths} #{absl_path}" unless paths.include?(absl_path)
      end
    end
  end

  # Inject SWIFT_OBJC_BRIDGING_HEADER into the Pods-iosApp xcconfig so the
  # iosApp target picks it up without modifying the .xcodeproj directly.
  ['Pods-iosApp.debug.xcconfig', 'Pods-iosApp.release.xcconfig'].each do |name|
    path = File.join(installer.sandbox.root, 'Target Support Files', 'Pods-iosApp', name)
    next unless File.exist?(path)
    content = File.read(path)
    unless content.include?('SWIFT_OBJC_BRIDGING_HEADER')
      File.open(path, 'a') { |f| f.puts('SWIFT_OBJC_BRIDGING_HEADER = $(SRCROOT)/iosApp/iosApp-Bridging-Header.h') }
    end
    unless content.include?('SWIFT_ENABLE_EXPLICIT_MODULES')
      File.open(path, 'a') { |f| f.puts('SWIFT_ENABLE_EXPLICIT_MODULES = NO') }
    end
  end
end

